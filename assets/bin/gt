#!/bin/sh

OSC_START="$(printf '\033]7717;')"
OSC_END="$(printf '\007')"
MAX_BYTES=65536
# 1メッセージの生データ上限。base64 で約1.37倍に膨らむ。
# Windows のコンソール層（ConPTY）は長い OSC 文字列を黙って落とすため、
# ヘッダ込みでも 4KB を大きく下回るサイズに抑える（8192 では Windows で届かなかった）。
CHUNK_BYTES=2048

has_tty() {
    [ -w /dev/tty ]
}

b64() {
    base64 | tr -d '\n'
}

b64_arg() {
    printf '%s' "$1" | b64
}

emit() {
    has_tty || return 0
    printf '%s%s%s' "$OSC_START" "$1" "$OSC_END" > /dev/tty
}

send_event() {
    kind=$1
    path=$2
    tool=$3

    case "$kind" in
        new|mod|del) ;;
        *) return 0 ;;
    esac

    path_b64=$(b64_arg "$path")
    msg="event;kind=$kind;path=$path_b64"
    if [ -n "$tool" ]; then
        tool_b64=$(b64_arg "$tool")
        msg="$msg;tool=$tool_b64"
    fi
    emit "$msg"
}

send_state() {
    agent=$1
    state=$2
    detail=$3

    case "$state" in
        blocked|done|session_start|session_end) ;;
        *) return 0 ;;
    esac

    agent_b64=$(b64_arg "$agent")
    msg="state;agent=$agent_b64;state=$state"
    if [ -n "$detail" ]; then
        detail_b64=$(b64_arg "$detail")
        msg="$msg;detail=$detail_b64"
    fi
    emit "$msg"
}

send_view() {
    file=$1
    [ -r "$file" ] || return 0

    size=$(wc -c < "$file" 2>/dev/null | tr -d ' ')
    case "$size" in
        ''|*[!0-9]*) return 0 ;;
    esac

    start=0
    if [ "$size" -gt "$MAX_BYTES" ]; then
        start=$((size - MAX_BYTES))
    fi

    path_b64=$(b64_arg "$file")
    offset=$start
    seq=0
    while [ "$offset" -lt "$size" ]; do
        remaining=$((size - offset))
        count=$CHUNK_BYTES
        if [ "$remaining" -le "$CHUNK_BYTES" ]; then
            count=$remaining
            last=1
        else
            last=0
        fi
        data=$(dd if="$file" bs=1 skip="$offset" count="$count" 2>/dev/null | b64)
        emit "file;path=$path_b64;seq=$seq;last=$last;data=$data"
        offset=$((offset + count))
        seq=$((seq + 1))
    done
}

json_string_fallback() {
    key=$1
    sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" | head -n 1
}

# hooks の JSON からフィールドを1つ取り出す。
# $1=input(JSON文字列)  $2=jq用フィルタ(先頭.付き、例 .tool_input.file_path)
# $3=フォールバック用の素のキー名(ネストは無視して素朴に探す、例 file_path)
hook_field() {
    input=$1
    jq_filter=$2
    fallback_key=$3
    if command -v jq >/dev/null 2>&1; then
        printf '%s' "$input" | jq -r "$jq_filter // empty" 2>/dev/null
    else
        printf '%s' "$input" | json_string_fallback "$fallback_key"
    fi
}

run_hook() {
    input=$(cat)
    event=$(hook_field "$input" '.hook_event_name' 'hook_event_name')

    case "$event" in
        Notification)
            message=$(hook_field "$input" '.message' 'message')
            send_state claude blocked "$message"
            ;;
        Stop)
            send_state claude done ""
            ;;
        SessionStart)
            send_state claude session_start ""
            ;;
        SessionEnd)
            send_state claude session_end ""
            ;;
        *)
            # PostToolUse、または hook_event_name が来ない古い呼び出し。
            run_post_tool_use_hook "$input"
            ;;
    esac
}

run_post_tool_use_hook() {
    input=$1
    tool=$(hook_field "$input" '.tool_name' 'tool_name')
    path=$(hook_field "$input" '.tool_input.file_path' 'file_path')

    [ -n "$path" ] || return 0

    kind=mod
    if [ "$tool" = "Write" ]; then
        kind=new
    fi
    send_event "$kind" "$path" "$tool"
    case "$kind" in
        new|mod) send_view "$path" ;;
    esac
}

hook_snippet() {
    cat <<'EOF'
{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "gt hook"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gt hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gt hook"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gt hook"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "gt hook"
          }
        ]
      }
    ]
  }
}
EOF
}

init_hooks() {
    settings=.claude/settings.local.json
    if [ -e "$settings" ]; then
        printf '%s\n' "$settings already exists. Merge this snippet manually:" >&2
        hook_snippet >&2
        return 1
    fi
    mkdir -p .claude || return 1
    hook_snippet > "$settings"
    printf '%s\n' "wrote $settings"
}

usage() {
    cat <<'EOF'
usage:
  gt view <file>
  gt event <new|mod|del> <path> [tool]
  gt hook
  gt init-hooks
EOF
}

cmd=$1
shift 2>/dev/null || true

case "$cmd" in
    view)
        [ $# -eq 1 ] || { usage >&2; exit 2; }
        send_view "$1"
        ;;
    event)
        [ $# -ge 2 ] || { usage >&2; exit 2; }
        send_event "$1" "$2" "${3:-}"
        ;;
    hook)
        run_hook
        ;;
    init-hooks)
        init_hooks
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
